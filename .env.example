
# -----------------------------------------------------------------------------
# CONFIGURACIÓN DEL FRONTEND (Vercel)
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=tu_url_de_supabase
VITE_SUPABASE_ANON_KEY=tu_anon_key_de_supabase

# Clave pública de Stripe (Debe empezar por pk_live_ para producción)
VITE_STRIPE_PUBLIC_KEY=pk_live_tu_clave_publica_aqui
# Opcional (si usas convención Next.js)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_tu_clave_publica_aqui

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DEL BACKEND (Supabase Vault / Edge Functions)
# Estas variables deben configurarse con 'supabase secrets set NOMBRE=VALOR'
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_tu_clave_secreta_aqui
# STRIPE_WEBHOOK_SECRET=whsec_tu_secreto_del_webhook
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_para_bypass_rls
# GEMINI_API_KEY=tu_clave_de_google_ai_studio
